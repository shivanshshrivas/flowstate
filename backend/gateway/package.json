{
  "name": "@flowstate/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "*.js",
    "*.d.ts",
    "*.js.map",
    "types/**/*.js",
    "types/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./server": {
      "types": "./server.d.ts",
      "import": "./server.js",
      "default": "./server.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "pack": "tsc && npm pack"
  },
  "peerDependencies": {
    "react": ">=18",
    "lucide-react": ">=0.300.0",
    "clsx": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/node": "^22.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.515.0",
    "react": "^19.0.0",
    "typescript": "^5.9.3"
  }
}
