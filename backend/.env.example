# ─── Database ──────────────────────────────────────────────────────────────────
# Source: Supabase dashboard → Project → Connect → Transaction pooler (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Shippo ────────────────────────────────────────────────────────────────────
# Source: goshippo.com → Dashboard → API → API Keys → Test or Live key
SHIPPO_KEY=shippo_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Platform Defaults ─────────────────────────────────────────────────────────
PLATFORM_FEE_BPS=250
GRACE_PERIOD_HOURS=48

# ─── Redis (optional) ──────────────────────────────────────────────────────────
# Source: console.upstash.com → Create Database → Connect → .env tab
REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# ─── Pinata IPFS ───────────────────────────────────────────────────────────────
# Source: app.pinata.cloud → API Keys → New Key → Admin permissions
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Source: app.pinata.cloud → Gateways → your gateway domain
PINATA_GATEWAY=https://[your-subdomain].mypinata.cloud

# ─── Pinata OpenClaw Agents ────────────────────────────────────────────────────
# Source: agents.pinata.cloud → your agent → Settings → Gateway Token
PINATA_BUYER_AGENT_URL=wss://[agent-id].agents.pinata.cloud
PINATA_BUYER_AGENT_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PINATA_SELLER_AGENT_URL=wss://[agent-id].agents.pinata.cloud
PINATA_SELLER_AGENT_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PINATA_ADMIN_AGENT_URL=wss://[agent-id].agents.pinata.cloud
PINATA_ADMIN_AGENT_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── MCP Agents ────────────────────────────────────────────────────────────────
# Source: run `cd mcp-agents && npm run dev` then `ngrok http 3001`
MCP_AGENTS_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app

# ─── OpenRouter ────────────────────────────────────────────────────────────────
# Source: openrouter.ai → Keys → Create Key
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
