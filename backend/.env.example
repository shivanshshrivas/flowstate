# ═══════════════════════════════════════════════════════════════════════════════
# FlowState Backend — Environment Variables
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Get from: supabase.com → Project → Connect → Transaction pooler
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Shippo shipping API key
# Get from: goshippo.com → Dashboard → API → API Keys
SHIPPO_KEY=shippo_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OPTIONAL (server defaults if omitted) ─────────────────────────────────────

PORT=3000
NODE_ENV=development
PLATFORM_FEE_BPS=250
GRACE_PERIOD_HOURS=48

# ─── OPTIONAL SERVICES ─────────────────────────────────────────────────────────
# These degrade gracefully — the backend runs without them

# Redis for job queues (without it: sync fallback mode)
# Get from: console.upstash.com → Create Database → .env tab
# REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# Pinata IPFS for invoices/labels (without it: stub implementation)
# Get from: app.pinata.cloud → API Keys → New Key
# PINATA_JWT=eyJhbGciOi...
# Get from: app.pinata.cloud → Gateways → your domain
# PINATA_GATEWAY=https://[subdomain].mypinata.cloud

# MCP agents server for AI chat (without it: chat endpoint returns error)
# Get from: run `cd mcp-agents && npm run dev` then `ngrok http 3001`
# MCP_AGENTS_URL=http://localhost:3001
