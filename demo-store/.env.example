# ─── FlowState Backend ─────────────────────────────────────────────────────────
# Source: your deployed Railway backend URL (or http://localhost:3000 in dev)
NEXT_PUBLIC_FLOWSTATE_API_URL=http://localhost:3000
# Source: backend DB → platform_config table → flowstate_api_key
# Or run: POST /api/v1/auth/projects/create on the backend
NEXT_PUBLIC_FLOWSTATE_API_KEY=fs_live_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FLOWSTATE_PROJECT_ID=demo

# Server-side (for API routes — same values as above)
FLOWSTATE_API_URL=http://localhost:3000
FLOWSTATE_API_KEY=fs_live_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Source: set any random secret, register it via POST /api/v1/webhooks/register
FLOWSTATE_WEBHOOK_SECRET=

# ─── XRPL EVM Contract Addresses (chain-1449000) ───────────────────────────────
# Source: packages/contracts/ignition/deployments/chain-1449000/deployed_addresses.json
NEXT_PUBLIC_MOCK_RLUSD_ADDRESS=0x257812213360Df9f3C19cAe9759B58cAcf39323d
NEXT_PUBLIC_ESCROW_STATE_MACHINE_ADDRESS=0x33136ca845ace5a4f8CC032793AF22eC024B2ee3
NEXT_PUBLIC_DISPUTE_RESOLVER_ADDRESS=0x9A2C9B4CE17eE3ffD5C3Db97a04009381f457731
NEXT_PUBLIC_PAYMENT_SPLITTER_ADDRESS=

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# Source: cloud.walletconnect.com → Create Project → Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase (optional — for auth/user features) ──────────────────────────────
# Source: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Site ──────────────────────────────────────────────────────────────────────
# Source: your deployed demo-store URL (or http://localhost:3001 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
