# ═══════════════════════════════════════════════════════════════════════════════
# FlowState Demo Store — Environment Variables
# Copy this file to .env.local and fill in values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── FlowState Backend Connection ──────────────────────────────────────────────

# Client-side (browser)
# Local dev: http://localhost:3000 | Production: your Railway URL
NEXT_PUBLIC_FLOWSTATE_API_URL=http://localhost:3000
# Get from: POST /api/v1/auth/projects/create on backend, or use demo key
NEXT_PUBLIC_FLOWSTATE_API_KEY=fs_live_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FLOWSTATE_PROJECT_ID=demo

# Server-side (API routes — same backend URL/key, no NEXT_PUBLIC_ prefix)
FLOWSTATE_API_URL=http://localhost:3000
FLOWSTATE_API_KEY=fs_live_key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# For webhook signature verification — set any random string, then register
# it via POST /api/v1/webhooks/register on the backend
# FLOWSTATE_WEBHOOK_SECRET=your-webhook-secret

# ─── XRPL EVM Contract Addresses ──────────────────────────────────────────────
# Get from: packages/contracts/ignition/deployments/chain-1449000/deployed_addresses.json
# These are already deployed on XRPL EVM testnet (chain ID 1449000)
NEXT_PUBLIC_MOCK_RLUSD_ADDRESS=0x257812213360Df9f3C19cAe9759B58cAcf39323d
NEXT_PUBLIC_ESCROW_STATE_MACHINE_ADDRESS=0x33136ca845ace5a4f8CC032793AF22eC024B2ee3
NEXT_PUBLIC_DISPUTE_RESOLVER_ADDRESS=0x9A2C9B4CE17eE3ffD5C3Db97a04009381f457731

# ─── WalletConnect ─────────────────────────────────────────────────────────────
# Get from: cloud.walletconnect.com → New Project → Project ID
# Falls back to "demo" if not set (will work locally but may rate-limit)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase (optional — for login/auth features) ────────────────────────────
# Get from: supabase.com → Project → Settings → API
# Without these, the store runs in anonymous/demo mode
# NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001
